+
+pub fn Padding(
+    _: *Seat,
+    args: []const [:0]const u8,
+    _: *?[]const u8,
+) Error!void {
+    if (args.len < 2) return Error.NotEnoughArguments;
+    if (args.len > 2) return Error.TooManyArguments;
+
+    server.config.padding = try fmt.parseInt(u31, args[1], 10);
+    server.root.applyPending();
+}
diff -urdN river-classic/river/command/maximize.zig river-classic.maximize_padding/river/command/maximize.zig
--- river-classic/river/command/maximize.zig	1970-01-01 07:00:00.000000000 +0700
+++ river-classic.maximize_padding/river/command/maximize.zig	2026-04-28 14:43:57.145498583 +0700
@@ -0,0 +1,53 @@
+const std = @import("std");
+const math = std.math;
+
+const server = &@import("../main.zig").server;
+
+const Error = @import("../command.zig").Error;
+const Seat = @import("../Seat.zig");
+const View = @import("../View.zig");
+
+fn apply(view: *View) void {
+    // Set the view to floating but keep the position and dimensions, if their
+    // dimensions are set by a layout generator. If however the views are
+    // unarranged, leave them as non-floating so the next active layout can
+    // affect them.
+    if (view.pending.output == null or view.pending.output.?.layout != null) {
+        view.pending.float = true;
+    }
+
+    server.root.applyPending();
+}
+
+fn getView(seat: *Seat) ?*View {
+    if (seat.focused != .view) return null;
+    const view = seat.focused.view;
+
+    // Do not touch fullscreen views
+    if (view.pending.fullscreen) return null;
+
+    return view;
+}
+
+pub fn Maximize(
+    seat: *Seat,
+    args: []const [:0]const u8,
+    _: *?[]const u8,
+) Error!void {
+    if (args.len > 1) return Error.TooManyArguments;
+
+    const view = getView(seat) orelse return;
+    const output = view.pending.output orelse return;
+    const padding = server.config.padding;
+
+    var output_width: c_int = math.maxInt(c_int);
+    var output_height: c_int = math.maxInt(c_int);
+    output.wlr_output.effectiveResolution(&output_width, &output_height);
+
+    view.pending.box.x = padding;
+    view.pending.box.y = padding;
+    view.pending.box.width = output_width - (padding * 2);
+    view.pending.box.height = output_height - (padding * 2);
+    
+    apply(view);
+}
